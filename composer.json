{
    "name": "adelinferaru/laravel-websms",
    "description": "Laravel package for sending SMS through the WebSMS.com.cy gateway.",
    "type": "library",
    "keywords": ["laravel", "websms", "sms", "cyprus"],
    "license": "MIT",
    "authors": [
        {
            "name": "Feraru Ioan Adelin",
            "email": "adelin.feraru@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-soap": "*",
        "illuminate/contracts": "^12.0 || ^13.0",
        "illuminate/support": "^12.0 || ^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.10",
        "laravel/pint": "^1.13",
        "orchestra/testbench": "^10.11 || ^11.1",
        "phpunit/phpunit": "^11.5 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "Adelinferaru\\LaravelWebSms\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Adelinferaru\\LaravelWebSms\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Adelinferaru\\LaravelWebSms\\WebSmsServiceProvider"
            ],
            "aliases": {
                "WebSms": "Adelinferaru\\LaravelWebSms\\Facades\\WebSms"
            }
        }
    },
    "scripts": {
        "analyse": "phpstan analyse",
        "lint": "pint --test",
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
